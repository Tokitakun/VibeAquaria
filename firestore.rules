rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    match /notes/{noteId} {
      // Basic rule for owner access only
      allow read, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(noteId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidId(noteId) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /ecoCareNotes/{noteId} {
      allow read, delete: if isSignedIn() && existing().userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(noteId) && incoming().userId == request.auth.uid && incoming().keys().hasAll(["userId", "title", "text", "isCompleted", "createdAt"]);
      allow update: if isSignedIn() && isValidId(noteId) && existing().userId == request.auth.uid && incoming().userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['isCompleted']);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
